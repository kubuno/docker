# Copiez ce fichier en .env (lu automatiquement par docker compose) puis
# renseignez les valeurs. NE COMMITEZ JAMAIS le .env rempli.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=kubuno
POSTGRES_PASSWORD=changez_moi_mot_de_passe_postgres
POSTGRES_DB=kubuno

# ── Secrets Kubuno (OBLIGATOIRES) ─────────────────────────────────────────────
# JWT (≥ 32 caractères)        →  openssl rand -base64 48
KUBUNO_JWT_SECRET=changez_moi_cle_jwt_longue_et_aleatoire_min_32
# Secret interne core ↔ modules →  openssl rand -hex 32
KUBUNO_INTERNAL_SECRET=changez_moi_secret_interne

# ── Compte admin initial (optionnel) ──────────────────────────────────────────
# Seedé au tout premier démarrage si aucun admin n'existe. Défauts : admin/kubuno.
# Décommentez pour personnaliser AVANT le premier démarrage.
# KUBUNO_ADMIN_USER=admin
# KUBUNO_ADMIN_PASSWORD=changez_moi_mot_de_passe_admin
# KUBUNO_ADMIN_EMAIL=admin@kubuno.local

# ── Réseau ────────────────────────────────────────────────────────────────────
# Port exposé sur l'hôte (le conteneur écoute toujours sur 8080).
KUBUNO_PORT=8080
